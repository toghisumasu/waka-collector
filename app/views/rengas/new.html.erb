<h1>連歌 — 前句を入力</h1>

<% if flash[:alert] %>
  <p style="color:#b00"><%= flash[:alert] %></p>
<% end %>

<% if @warning %>
  <p style="color:#c60"><strong><%= @warning %></strong></p>
<% end %>

<%= form_with model: @renga do |f| %>
  <%= f.hidden_field :previous_renga_id %>
  <div>
    <%= f.label :maeku, "前句（五七五）" %><br>
    <%= f.text_area :maeku,
          placeholder: "春はあけぼの やうやう白く なりゆく山ぎは" %>
  </div>

  <fieldset>
    <legend>本歌参照候補</legend>
    <% @honkas.each do |honka| %>
      <label>
        <%= check_box_tag "renga[honka_ids][]", honka.id %>
        <%= honka.upper_phrase_text.to_s + honka.lower_phrase_text.to_s + "（" + honka.author.to_s + "）" %>
      </label><br>
    <% end %>
  </fieldset>

  <% if @confirmed %>
    <%= hidden_field_tag :confirmed, "true" %>
    <%= f.submit "字余りのまま続ける" %>
    <%= f.submit "差し戻す" %>
  <% else %>
    <%= f.submit "付け句を生成する" %>
  <% end %>
<% end %>
